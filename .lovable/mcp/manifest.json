{
  "version": 1,
  "sdk_version": "0.24.0",
  "path": "/functions/v1/mcp",
  "auth": {
    "type": "oauth",
    "issuer": "https://itprvihlhgcrajbsbfta.supabase.co/auth/v1",
    "accepted_audiences": [
      "authenticated"
    ]
  },
  "mcp": {
    "server": {
      "name": "km0lab-mcp",
      "version": "0.1.0",
      "title": "KM0 Lab MCP"
    },
    "tools": [
      {
        "name": "get_profile",
        "title": "Get my profile",
        "description": "Returns the signed-in user's KM0 Lab profile (name, email, postal code, town).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "query_local_events",
        "title": "Query local events",
        "description": "Search local events near the signed-in user using the KM0 Lab event-query engine. Uses the user's saved postal code by default; pass postal_code to override.",
        "annotations": {
          "readOnlyHint": true,
          "openWorldHint": true
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "question": {
              "type": "string",
              "minLength": 1,
              "description": "Natural-language question about local events."
            },
            "postal_code": {
              "type": "string",
              "description": "Optional 5-digit Spanish postal code. Defaults to the user's profile postal code."
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 50,
              "description": "Max events to return (default 20)."
            }
          },
          "required": [
            "question"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      }
    ]
  }
}
